{
  "name": "@contacthi/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the CHI/1.0 agent-to-human communication protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "contacthi",
    "protocol",
    "agent",
    "communication",
    "cosmos",
    "did",
    "async-messaging"
  ],
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0",
    "@cosmjs/cosmwasm-stargate": "^0.32.0",
    "@cosmjs/stargate": "^0.32.0",
    "@noble/ed25519": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@contacthi/sdk$": "<rootDir>/src/index.ts",
      "^@noble/ed25519$": "<rootDir>/node_modules/@noble/ed25519/index.js"
    },
    "transform": {
      "^.+\\.tsx?$": "ts-jest",
      "^.+node_modules/@noble/ed25519.+\\.js$": ["ts-jest", { "useESM": false }]
    },
    "setupFiles": ["<rootDir>/tests/setup.ts"],
    "transformIgnorePatterns": [
      "node_modules/(?!(@noble/ed25519)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts"
    ]
  }
}
